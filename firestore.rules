
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidContext(data) {
      return data.context is string
             && data.context in ['Trabajo', 'Estudio'];
    }

    function isValidPriority(data) {
      return data.priority is string
             && data.priority in ['baja', 'media', 'alta'];
    }

    function isValidTimestampField(value) {
      return value is timestamp;
    }

    function isValidTags(tags) {
      return tags is list && tags.size() <= 20;
    }

    function isValidUserDoc(data) {
      return data.keys().hasOnly(['displayName', 'email', 'updatedAt', 'createdAt'])
             && (!('displayName' in data) || data.displayName is string)
             && (!('email' in data) || data.email is string)
             && (!('updatedAt' in data) || isValidTimestampField(data.updatedAt))
             && (!('createdAt' in data) || isValidTimestampField(data.createdAt));
    }

    function isValidTaskDoc(data, userId) {
      return data.keys().hasOnly([
               'userId', 'title', 'description', 'priority', 'status', 'tags',
               'dueDate', 'context', 'createdAt', 'updatedAt'
             ])
             && data.userId == userId
             && data.title is string
             && data.title.size() > 0
             && data.title.size() <= 140
             && (!('description' in data) || (data.description is string && data.description.size() <= 2000))
             && data.status is string
             && data.status.size() > 0
             && isValidContext(data)
             && isValidPriority(data)
             && (!('tags' in data) || isValidTags(data.tags))
             && (!('dueDate' in data) || (data.dueDate is string || isValidTimestampField(data.dueDate)))
             && (!('createdAt' in data) || isValidTimestampField(data.createdAt))
             && (!('updatedAt' in data) || isValidTimestampField(data.updatedAt));
    }

    function isValidRoutineDoc(data, userId) {
      return data.keys().hasOnly([
               'userId', 'title', 'startTime', 'endTime', 'recurringDays',
               'priority', 'context', 'color', 'createdAt', 'updatedAt'
             ])
             && data.userId == userId
             && data.title is string
             && data.title.size() > 0
             && data.startTime is string
             && data.endTime is string
             && data.recurringDays is list
             && data.recurringDays.size() <= 7
             && isValidContext(data)
             && isValidPriority(data)
             && (!('color' in data) || data.color is string)
             && (!('createdAt' in data) || isValidTimestampField(data.createdAt))
             && (!('updatedAt' in data) || isValidTimestampField(data.updatedAt));
    }

    function isValidEventDoc(data, userId) {
      return data.keys().hasOnly([
               'userId', 'title', 'description', 'startDate', 'endDate', 'allDay',
               'location', 'color', 'context', 'createdAt', 'updatedAt'
             ])
             && data.userId == userId
             && data.title is string
             && data.title.size() > 0
             && data.startDate is string
             && data.endDate is string
             && data.allDay is bool
             && data.color is string
             && (!('description' in data) || data.description is string)
             && (!('location' in data) || data.location is string)
             && isValidContext(data)
             && (!('createdAt' in data) || isValidTimestampField(data.createdAt))
             && (!('updatedAt' in data) || isValidTimestampField(data.updatedAt));
    }

    function isValidTransactionDoc(data, userId) {
      return data.keys().hasOnly([
               'userId', 'title', 'amount', 'type', 'category', 'date',
               'context', 'description', 'isRecurring', 'recurrenceInterval',
               'parentTransactionId', 'createdAt', 'updatedAt'
             ])
             && data.userId == userId
             && data.title is string
             && data.title.size() > 0
             && data.title.size() <= 140
             && (data.amount is int || data.amount is float)
             && data.amount > 0
             && data.type is string
             && data.type in ['ingreso', 'gasto']
             && data.category is string
             && data.category in [
                  'Alquiler/Hipoteca', 'Servicios', 'Comida/Super', 'Transporte',
                  'Salud', 'Ocio', 'Sueldo', 'Inversiones', 'Otros'
                ]
             && data.date is string
             && data.context is string
             && data.context in ['Personal', 'Hogar', 'Trabajo']
             && (!('description' in data) || data.description is string)
             && (!('isRecurring' in data) || data.isRecurring is bool)
             && (!('recurrenceInterval' in data) || (data.recurrenceInterval is string && data.recurrenceInterval in ['semanal', 'mensual', 'anual']))
             && (!('parentTransactionId' in data) || data.parentTransactionId is string)
             && (!('createdAt' in data) || isValidTimestampField(data.createdAt))
             && (!('updatedAt' in data) || isValidTimestampField(data.updatedAt));
    }

    function isValidSettingsDoc(data) {
      return data.keys().hasOnly([
               'context', 'theme', 'colorMode', 'activeModules', 'highPerformanceMode',
               'kanbanColumns', 'hourFormat', 'defaultPage', 'autoDeleteDoneDays',
               'visualConfig', 'updatedAt'
             ])
             && (!('context' in data) || isValidContext(data))
             && (!('theme' in data) || (data.theme is string && data.theme in [
                  'neon', 'cyan', 'amber', 'rose', 'violet', 'emerald', 'indigo', 'crimson', 'slate'
                ]))
             && (!('colorMode' in data) || (data.colorMode is string && data.colorMode in ['dark', 'light']))
             && (!('activeModules' in data) || data.activeModules is map)
             && (!('highPerformanceMode' in data) || data.highPerformanceMode is bool)
             && (!('kanbanColumns' in data) || data.kanbanColumns is list)
             && (!('hourFormat' in data) || (data.hourFormat is string && data.hourFormat in ['24h', '12h']))
             && (!('defaultPage' in data) || data.defaultPage is string)
             && (!('autoDeleteDoneDays' in data) || data.autoDeleteDoneDays is string)
             && (!('visualConfig' in data) || data.visualConfig is map)
             && (!('updatedAt' in data) || isValidTimestampField(data.updatedAt));
    }

    function isValidDeviceDoc(data, userId) {
      return data.keys().hasOnly([
               'userId', 'platform', 'pushToken', 'appVersion', 'osVersion', 'deviceModel',
               'locale', 'timezone', 'isActive', 'createdAt', 'updatedAt', 'lastSeenAt'
             ])
             && data.userId == userId
             && data.platform is string
             && data.platform in ['android', 'web']
             && data.pushToken is string
             && data.pushToken.size() >= 20
             && data.pushToken.size() <= 4096
             && (!('appVersion' in data) || data.appVersion is string)
             && (!('osVersion' in data) || data.osVersion is string)
             && (!('deviceModel' in data) || data.deviceModel is string)
             && (!('locale' in data) || data.locale is string)
             && (!('timezone' in data) || data.timezone is string)
             && (!('isActive' in data) || data.isActive is bool)
             && (!('createdAt' in data) || isValidTimestampField(data.createdAt))
             && (!('updatedAt' in data) || isValidTimestampField(data.updatedAt))
             && (!('lastSeenAt' in data) || isValidTimestampField(data.lastSeenAt));
    }

    function isValidMobileLogDoc(data, userId) {
      return data.keys().hasOnly([
               'userId', 'name', 'source', 'level', 'appBuild', 'correlationId', 'data', 'createdAt'
             ])
             && data.userId == userId
             && data.name is string
             && data.source is string
             && data.source in ['android', 'web']
             && (!('level' in data) || (data.level is string && data.level in ['debug', 'info', 'warn', 'error']))
             && (!('appBuild' in data) || data.appBuild is string)
             && (!('correlationId' in data) || data.correlationId is string)
             && (!('data' in data) || data.data is map)
             && (!('createdAt' in data) || isValidTimestampField(data.createdAt));
    }

    function isNotificationReadUpdateOnly() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(['readAt', 'openedAt', 'updatedAt']);
    }

    // ── Perfil de usuario ──────────────────────────────────────
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
                    && isValidUserDoc(request.resource.data);
      allow update: if isOwner(userId)
                    && isValidUserDoc(request.resource.data);
      allow delete: if isOwner(userId);

      // ── Configuraciones del usuario ────────────────────────
      match /settings/{settingId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId)
                      && isValidSettingsDoc(request.resource.data);
        allow update: if isOwner(userId)
                      && isValidSettingsDoc(request.resource.data);
        allow delete: if isOwner(userId);
      }

      // ── Tareas del usuario (Kanban) ────────────────────────
      match /tasks/{taskId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && isValidTaskDoc(request.resource.data, userId);

        allow update: if isOwner(userId)
                      && isValidTaskDoc(request.resource.data, userId);

        allow delete: if isOwner(userId);
      }

      // ── Rutinas del usuario (Horario semanal) ──────────────
      match /routines/{routineId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && isValidRoutineDoc(request.resource.data, userId);

        allow update: if isOwner(userId)
                      && isValidRoutineDoc(request.resource.data, userId);

        allow delete: if isOwner(userId);
      }

      // ── Eventos del usuario (Calendario puntual) ───────────
      match /events/{eventId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && isValidEventDoc(request.resource.data, userId);

        allow update: if isOwner(userId)
                      && isValidEventDoc(request.resource.data, userId);

        allow delete: if isOwner(userId);
      }

      // ── Dispositivos para push (web y android) ─────────────
      match /devices/{deviceId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && isValidDeviceDoc(request.resource.data, userId);

        allow update: if isOwner(userId)
                      && isValidDeviceDoc(request.resource.data, userId);

        allow delete: if isOwner(userId);
      }

      // ── Notificaciones persistidas del usuario ──────────────
      match /notifications/{notificationId} {
        allow read: if isOwner(userId);

        // Las notificaciones se crean desde backend trusted (admin SDK).
        allow create: if false;

        // El cliente solo puede confirmar lectura/apertura.
        allow update: if isOwner(userId)
                      && isNotificationReadUpdateOnly();

        allow delete: if false;
      }

      // ── Transacciones financieras del usuario ──────────────
      match /transactions/{transactionId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && isValidTransactionDoc(request.resource.data, userId);

        allow update: if isOwner(userId)
                      && isValidTransactionDoc(request.resource.data, userId);

        allow delete: if isOwner(userId);
      }

      // ── Logs móviles para observabilidad ────────────────────
      match /mobile_logs/{logId} {
        allow read: if isOwner(userId);

        allow create: if isOwner(userId)
                      && isValidMobileLogDoc(request.resource.data, userId);

        allow update, delete: if false;
      }
    }

    // ── Denegar todo lo demás ────────────────────────────────
    match /{path=**} {
      allow read, write: if false;
    }
  }
}

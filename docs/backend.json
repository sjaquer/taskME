
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Perfil de usuario maestro vinculado a Firebase Auth.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "createdAt", "updatedAt"]
    },
    "UserConfig": {
      "title": "UserConfig",
      "description": "Preferencias y configuración de la aplicación persistentes en la nube.",
      "type": "object",
      "properties": {
        "activeModules": {
          "type": "object",
          "properties": {
            "dashboard": { "type": "boolean" },
            "kanban": { "type": "boolean" },
            "schedule": { "type": "boolean" },
            "calendar": { "type": "boolean" }
          }
        },
        "highPerformanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "Entidad unificada para gestión de Kanban, Schedule y Calendar.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "string", "enum": ["baja", "media", "alta"] },
        "context": { "type": "string", "enum": ["Trabajo", "Estudio"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "scheduledStartTime": { "type": "string", "format": "date-time" },
        "scheduledEndTime": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isRecurring": { "type": "boolean" },
        "recurrenceType": { "type": "string", "enum": ["none", "weekly", "monthly"] },
        "recurringDays": { "type": "array", "items": { "type": "integer" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "title", "status", "context", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Documento de perfil de usuario."
    },
    "/users/{userId}/settings/app": {
      "schema": { "$ref": "#/entities/UserConfig" },
      "description": "Configuraciones globales de la aplicación del usuario."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "#/entities/Task" },
      "description": "Colección centralizada de tareas y eventos."
    }
  }
}
